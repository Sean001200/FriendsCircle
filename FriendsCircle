<!DOCTYPE html><html lang="en"><head>    <meta charset="UTF-8">    <meta name="viewport" content="width=device-width, initial-scale=1.0">    <title>Facebook Mockup</title>    <link rel="stylesheet" href="styles.css"></head><body>    <!-- Header -->    <header>        <div class="search-bar">            <input type="text" placeholder="Search">        </div>        <nav>            <a href="#">Home</a>            <a href="#">Messages</a>        </nav>    </header>    <!-- Main Section -->    <div class="main-container">        <!-- Profile Section -->        <section class="profile-section">            <div class="profile-photo"></div>            <div class="profile-info">                <h2>Profile Name</h2>                <p>@username</p>                <p>Birthday</p>                <div class="about-contact">                    <a href="#">About</a>                    <a href="#">Contact</a>                </div>            </div>        </section>        <!-- Friends Section -->        <section class="friends-section">            <h3>Friends</h3>            <div class="box"></div>            <div class="box"></div>            <div class="box"></div>            <h3>Following</h3>            <div class="box"></div>            <div class="box"></div>            <div class="box"></div>            <h3>Followers</h3>            <div class="box"></div>            <div class="box"></div>            <div class="box"></div>        </section>        <!-- Post Section -->        <section class="post-section">            <div class="post-header">                <button>Photo</button>                <button>Video</button>            </div>            <div class="post-content"></div>            <div class="post-actions">                <a href="#">Like</a>                <a href="#">Comment</a>                <a href="#">Share</a>                <button class="post-btn">POST</button>            </div>        </section>    </div></body></html>
